{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Generative Assistant",
  "version": "0.4.0",
  "identifier": "com.scramblerlab.assistant",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Generative Assistant",
        "width": 1200,
        "height": 800,
        "minWidth": 700,
        "minHeight": 500,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https://asset.localhost; connect-src http://localhost:11434 http://127.0.0.1:11434 ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../skills": "skills"
    },
    "macOS": {
      "signingIdentity": "3rd Party Mac Developer Application: Nobuyuki Hayashi (GXWN8P2ZSF)",
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "12.0",
      "infoPlist": "./Info.plist"
    }
  }
}
